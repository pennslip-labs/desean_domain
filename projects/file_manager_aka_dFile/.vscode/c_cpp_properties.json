{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/lib64/wx/include/gtk3-unicode-3.2",
                "/usr/include/wx-3.2"
            ],
            "defines": [
                "_FILE_OFFSET_BITS=64",
                "_LARGEFILE_SOURCE=",
                "WXUSINGDLL",
                "__WXGTK__"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": ["-pthread"]
        }
    ],
    "version": 4
}
